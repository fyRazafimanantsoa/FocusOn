{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "uid": { "type": "string" },
        "adhdMode": { "type": "boolean" },
        "weeklyGoalMinutes": { "type": "number" },
        "totalFocusMinutes": { "type": "number" },
        "projects": { "type": "array" }
      }
    },
    "Session": {
      "title": "Focus Session",
      "description": "A completed focus session block",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskName": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "number" },
        "reflectionNotes": { "type": "string" },
        "nextStep": { "type": "string" },
        "projectId": { "type": "string" }
      }
    },
    "Distraction": {
      "title": "Distraction Log",
      "description": "Logged distractions during sessions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "activity": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data"
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Focus sessions"
    },
    "/distractions/{distractionId}": {
      "schema": { "$ref": "#/entities/Distraction" },
      "description": "Distraction logs"
    }
  }
}
